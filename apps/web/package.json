{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test:sentry-scrubbing": "tsx --test lib/sentry-scrubbing.test.ts",
    "test:auth": "tsx --test \"features/auth/**/*.test.ts\" \"shared/**/*.test.ts\"",
    "test:onboarding": "tsx --test \"features/onboarding/**/*.test.ts\"",
    "test:e2e": "playwright test && playwright test --config=playwright.production.config.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.62.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "next": "16.2.10",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  }
}
