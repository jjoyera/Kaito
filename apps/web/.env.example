# Optional frontend observability. Leave unset to keep Sentry fully disabled.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Optional build-time source-map upload credentials. All three are required;
# when any value is missing, the plain Next.js config is used and upload is skipped.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
