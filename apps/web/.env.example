# Required public Supabase browser configuration for sign-in and private routes.
# These values are public configuration, not credentials. Never add service-role keys,
# access tokens, refresh tokens, or JWT secrets to this file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Base URL of the Kaito API (apps/api). Must match that API's KAITO_WEB_ORIGIN
# allowlist so the browser can call protected routes directly (CORS).
NEXT_PUBLIC_KAITO_API_URL=http://localhost:8000

# Optional frontend observability. Leave unset to keep Sentry fully disabled.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Optional build-time source-map upload credentials. All three are required;
# when any value is missing, the plain Next.js config is used and upload is skipped.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
