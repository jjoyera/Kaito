# Sentry — error tracking (all variables are optional)
# Leave SENTRY_DSN unset or empty to run without Sentry (local dev, CI).

# DSN from your Sentry project settings.
# When empty or unset, Sentry initialisation is skipped entirely.
SENTRY_DSN=

# Environment label shown in the Sentry UI (default: development).
SENTRY_ENVIRONMENT=development

# Fraction of requests to trace (0.0 = off, 1.0 = 100%).
# Defaults to 0.0 — opt-in for performance data.
SENTRY_TRACES_SAMPLE_RATE=0.0

# Fraction of traced requests to profile (0.0 = off, 1.0 = 100%).
# Defaults to 0.0 — opt-in.
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Debug/verification route — set to true ONLY for manual Sentry ingestion checks.
# When false or absent the /debug-sentry route is not registered (returns 404).
# NEVER set to true in production.
ENABLE_DEBUG_SENTRY=false

# ---------------------------------------------------------------------------
# Supabase Auth — backend token verification via JWT Signing Keys (JWKS).
# Verification uses asymmetric signing keys; no shared secret is used.
# SUPABASE_JWKS_URL is required for auth. Use the value from Supabase onboarding.
# Note: SUPABASE_SECRET_KEY (server-side API key) is NOT used for JWT verification.
# ---------------------------------------------------------------------------

# Explicit JWKS endpoint from Supabase onboarding (required for auth verification).
# Leave empty (or unset) to boot without auth: public routes (/health) still
# work; protected routes (/auth/me and future domain routes) return 503.
SUPABASE_JWKS_URL=

# Base URL of your Supabase project (optional/informational).
# Not used for JWKS URL derivation; auth is driven by SUPABASE_JWKS_URL above.
SUPABASE_URL=

# Expected token audience (Supabase default: "authenticated").
# Leave empty to disable audience verification (not recommended for production).
SUPABASE_JWT_AUDIENCE=authenticated

# Optional issuer check (e.g. https://<project-ref>.supabase.co/auth/v1).
# Leave empty to skip issuer verification.
SUPABASE_JWT_ISSUER=

# Optional JWKS in-process cache lifetime in seconds (default: 600).
SUPABASE_JWKS_CACHE_TTL_SECONDS=600

# Runtime onboarding persistence. Required when the API lifespan starts.
# This login must be exactly the non-privileged local role created by Supabase CLI.
DATABASE_URL=
DATABASE_EXPECTED_ROLE=kaito_api_login

# ---------------------------------------------------------------------------
# CORS — browser origins allowed to call this API directly.
# Leave unset to keep cross-origin browser access fully disabled (fail closed).
# Accepts a comma-separated list for more than one allowed origin.
# ---------------------------------------------------------------------------
KAITO_WEB_ORIGIN=http://localhost:3000
