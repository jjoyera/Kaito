{
  "name": "kaito",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=24.18 <25"
  },
  "workspaces": [
    "apps/web",
    "packages/api-client"
  ],
  "scripts": {
    "prepare": "husky",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "check:portable-paths": "node scripts/check-portable-paths.mjs",
    "test:portable-paths": "node --test scripts/check-portable-paths.test.mjs",
    "test:web-sentry-scrubbing": "pnpm --filter web test:sentry-scrubbing",
    "test:web-auth": "pnpm --filter web test:auth",
    "test:web-onboarding": "pnpm --filter web test:onboarding",
    "test:web-docker-build": "docker compose build web && docker compose run --rm --no-deps web sh -lc 'test -f apps/web/instrumentation.ts && test -f apps/web/instrumentation-client.ts'",
    "test:web-e2e": "pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "husky": "9.1.7"
  }
}
